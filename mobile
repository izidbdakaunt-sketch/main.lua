-- Исправленная функция WallCheck
local function IsVisible(part, targetCharacter)
    if not Config.WallCheck then return true end
    local origin = Camera.CFrame.Position
    local rParams = RaycastParams.new()
    rParams.FilterDescendantsInstances = {LocalPlayer.Character}
    rParams.FilterType = Enum.RaycastFilterType.Exclude
    local result = workspace:Raycast(origin, part.Position - origin, rParams)
    if result and result.Instance:IsDescendantOf(targetCharacter) then return true end
    if result and result.Instance.CanCollide and result.Instance.Transparency < 0.5 then return false end
    return true
end

-- Главный цикл
RunService.RenderStepped:Connect(function()
    FOV.Visible = Config.Aimlock
    FOV.Size = UDim2.new(0, Config.AimFOV * 2, 0, Config.AimFOV * 2)
    AimBtn.Visible = Config.Aimlock

    if Config.FullBright then
        Lighting.Brightness = 2; Lighting.ClockTime = 14; Lighting.GlobalShadows = false; Lighting.OutdoorAmbient = Color3.new(1,1,1)
    else
        Lighting.Brightness = Orig.Br; Lighting.ClockTime = Orig.Cl; Lighting.GlobalShadows = Orig.Sh; Lighting.OutdoorAmbient = Orig.Amb
    end

    if AimActive and Config.Aimlock then
        if LockedTarget and LockedTarget.Parent and LockedTarget.Parent:FindFirstChild("Humanoid") and LockedTarget.Parent.Humanoid.Health > 0 then
            local s, on = Camera:WorldToViewportPoint(LockedTarget.Position)
            local dist = (Vector2.new(s.X, s.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
            if on and dist <= Config.AimFOV and IsVisible(LockedTarget, LockedTarget.Parent) then
                Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, LockedTarget.Position + (LockedTarget.Velocity * Config.Prediction)), Config.Smoothness)
                return
            else LockedTarget = nil end
        end

        local t, d = nil, Config.AimFOV
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(Config.AimPart) then
                local p = v.Character[Config.AimPart]
                local s, on = Camera:WorldToViewportPoint(p.Position)
                if on then
                    local m = (Vector2.new(s.X, s.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if m < d and IsVisible(p, v.Character) then t = p; d = m end
                end
            end
        end
        LockedTarget = t
    end
end)

