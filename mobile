local function CreateToggle(txt, parent, key)
    local b = Instance.new("TextButton", parent); b.Size = UDim2.new(0.98, 0, 0, 38); b.BackgroundColor3 = Color3.fromRGB(30,30,30); b.Text = txt..": OFF"; b.TextColor3 = Color3.new(0.7,0.7,0.7); b.Font = Enum.Font.Gotham; Round(b, 6)
    b.MouseButton1Click:Connect(function()
        Config[key] = not Config[key]
        b.Text = txt..": "..(Config[key] and "ON" or "OFF")
        b.BackgroundColor3 = Config[key] and Color3.fromRGB(50,50,50) or Color3.fromRGB(30,30,30)
        b.TextColor3 = Config[key] and Color3.new(1,1,1) or Color3.new(0.7,0.7,0.7)
        if key == "FullBright" and not Config.FullBright then
            Lighting.Brightness = Orig.Br; Lighting.ClockTime = Orig.Cl; Lighting.GlobalShadows = Orig.Sh; Lighting.OutdoorAmbient = Orig.Amb; Lighting.FogEnd = Orig.Fg
        end
    end)
end

local function CreateSlider(txt, parent, key, min, max, dec)
    local f = Instance.new("Frame", parent); f.Size = UDim2.new(0.98, 0, 0, 50); f.BackgroundTransparency = 1
    local l = Instance.new("TextLabel", f); l.Size = UDim2.new(1, 0, 0, 20); l.Text = txt..": "..Config[key]; l.TextColor3 = Color3.new(1,1,1); l.Font = Enum.Font.Gotham; l.BackgroundTransparency = 1
    local s = Instance.new("Frame", f); s.Size = UDim2.new(1, 0, 0, 10); s.Position = UDim2.new(0,0,0,25); s.BackgroundColor3 = Color3.fromRGB(40,40,40); Round(s, 5)
    local fill = Instance.new("Frame", s); fill.Size = UDim2.new((Config[key]-min)/(max-min), 0, 1, 0); fill.BackgroundColor3 = Color3.new(1,1,1); Round(fill, 5)
    local function Upd(i)
        local p = math.clamp((i.Position.X - s.AbsolutePosition.X) / s.AbsoluteSize.X, 0, 1)
        local v = min + (max - min) * p
        if dec then v = math.floor(v * 100) / 100 end
        Config[key] = v; fill.Size = UDim2.new(p, 0, 1, 0); l.Text = txt..": "..Config[key]
    end
    s.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then Upd(i) end end)
end

