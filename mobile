RunService.RenderStepped:Connect(function()
    FOV.Visible = Config.Aimlock
    -- Центрирование круга по размеру
    FOV.Size = UDim2.new(0, Config.AimFOV * 2, 0, Config.AimFOV * 2)
    AimBtn.Visible = Config.Aimlock
    
    if Config.FullBright then 
        Lighting.Brightness = 2; Lighting.ClockTime = 14; Lighting.FogEnd = 100000; Lighting.GlobalShadows = false; Lighting.OutdoorAmbient = Color3.new(1,1,1) 
    end
    
    if AimActive and Config.Aimlock then
        local targetPart, minDistance = nil, Config.AimFOV
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(Config.AimPart) then
                local p = v.Character[Config.AimPart]
                local screenPos, onScreen = Camera:WorldToViewportPoint(p.Position)
                if onScreen then
                    local mouseDistance = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if mouseDistance < minDistance then
                        local isVisible = true
                        if Config.WallCheck then
                            local rayParams = RaycastParams.new()
                            rayParams.FilterDescendantsInstances = {LocalPlayer.Character, v.Character}
                            rayParams.FilterType = Enum.RaycastFilterType.Exclude
                            if workspace:Raycast(Camera.CFrame.Position, (p.Position - Camera.CFrame.Position).Unit * 500, rayParams) then 
                                isVisible = false 
                            end
                        end
                        if isVisible then 
                            targetPart = p
                            minDistance = mouseDistance 
                        end
                    end
                end
            end
        end
        if targetPart then 
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, targetPart.Position + (targetPart.Velocity * Config.Prediction)), Config.Smoothness) 
        end
    end
end)

-- Фикс ESP (Центрирование рамки)
local function AddESP(p)
    local b = Instance.new("Frame", ScreenGui)
    b.BackgroundTransparency = 1
    b.Visible = false
    local stroke = Instance.new("UIStroke", b)
    stroke.Color = Color3.new(1,1,1)
    
    local h = Instance.new("Frame", b)
    h.Size = UDim2.new(0, 2, 1, 0)
    h.Position = UDim2.new(0, -5, 0, 0)
    h.BackgroundColor3 = Color3.new(0,1,0)
    
    local n = Instance.new("TextLabel", b)
    n.Size = UDim2.new(1, 0, 0, 20)
    n.Position = UDim2.new(0, 0, 0, -20)
    n.BackgroundTransparency = 1
    n.TextColor3 = Color3.new(1,1,1)
    n.Font = Enum.Font.GothamBold
    n.TextSize = 10

    RunService.RenderStepped:Connect(function()
        if Config.ESP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local root = p.Character.HumanoidRootPart
            local pos, on = Camera:WorldToViewportPoint(root.Position)
            if on then
                local sz = 4500 / pos.Z -- Слегка подкорректирован размер
                b.Visible = true
                b.Size = UDim2.new(0, sz * 0.7, 0, sz)
                -- Центрируем рамку: вычитаем половину размера из экранных координат
                b.Position = UDim2.new(0, pos.X - (b.Size.X.Offset / 2), 0, pos.Y - (b.Size.Y.Offset / 2))
                
                h.Visible = Config.ESPHealth
                n.Visible = Config.ESPNames
                n.Text = p.Name .. (Config.ESPDistance and " ["..math.floor(pos.Z).."]" or "")
                
                if p.Character:FindFirstChild("Humanoid") then 
                    h.Size = UDim2.new(0, 2, p.Character.Humanoid.Health/p.Character.Humanoid.MaxHealth, 0) 
                end
                return
            end
        end
        b.Visible = false
    end)
end

for _, v in pairs(Players:GetPlayers()) do if v ~= LocalPlayer then AddESP(v) end end
