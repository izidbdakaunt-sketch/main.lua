RunService.RenderStepped:Connect(function()
    FOV.Visible = Config.Aimlock; FOV.Size = UDim2.new(0, Config.AimFOV * 2, 0, Config.AimFOV * 2)
    AimBtn.Visible = Config.Aimlock
    if Config.FullBright then Lighting.Brightness = 2; Lighting.ClockTime = 14; Lighting.FogEnd = 100000; Lighting.GlobalShadows = false; Lighting.OutdoorAmbient = Color3.new(1,1,1) end
    if AimHold and Config.Aimlock then
        local t, d = nil, Config.AimFOV
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(Config.AimPart) then
                local p = v.Character[Config.AimPart]; local s, on = Camera:WorldToViewportPoint(p.Position)
                if on then
                    local m = (Vector2.new(s.X, s.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if m < d then t = p; d = m end
                end
            end
        end
        if t then Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, t.Position + (t.Velocity * Config.Prediction)), Config.Smoothness) end
    end
end)

local function AddESP(p)
    local b = Instance.new("Frame", ScreenGui); b.BackgroundTransparency = 1; b.Visible = false; Instance.new("UIStroke", b).Color = Color3.new(1,1,1)
    local h = Instance.new("Frame", b); h.Size = UDim2.new(0, 2, 1, 0); h.Position = UDim2.new(0, -5, 0, 0); h.BackgroundColor3 = Color3.new(0,1,0)
    local n = Instance.new("TextLabel", b); n.Size = UDim2.new(1, 0, 0, 20); n.Position = UDim2.new(0, 0, 0, -20); n.BackgroundTransparency = 1; n.TextColor3 = Color3.new(1,1,1); n.Font = Enum.Font.GothamBold; n.TextSize = 10
    RunService.RenderStepped:Connect(function()
        if Config.ESP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local cf, sz = p.Character:GetBoundingBox()
            local pos, on = Camera:WorldToViewportPoint(cf.Position)
            if on then
                local top = Camera:WorldToViewportPoint((cf * CFrame.new(0, sz.Y/2, 0)).Position)
                local bottom = Camera:WorldToViewportPoint((cf * CFrame.new(0, -sz.Y/2, 0)).Position)
                local height = math.abs(top.Y - bottom.Y)
                local width = height * 0.6
                
                b.Visible = true; b.Size = UDim2.new(0, width, 0, height); b.Position = UDim2.new(0, pos.X - width/2, 0, pos.Y - height/2)
                h.Visible = Config.ESPHealth; n.Visible = Config.ESPNames; n.Text = p.Name .. (Config.ESPDistance and " ["..math.floor(pos.Z).."]" or "")
                if p.Character:FindFirstChild("Humanoid") then h.Size = UDim2.new(0, 2, p.Character.Humanoid.Health/p.Character.Humanoid.MaxHealth, 0) end
                return
            end
        end
        b.Visible = false
    end)
end
for _, v in pairs(Players:GetPlayers()) do if v ~= LocalPlayer then AddESP(v) end end
Players.PlayerAdded:Connect(AddESP)

